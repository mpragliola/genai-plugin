{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/protect-sensitive-files.mjs", "timeout": 5 },
          { "type": "command", "command": "node .claude/hooks/block-main-branch.mjs", "timeout": 5 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/block-dangerous-commands.mjs", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/auto-format.mjs", "timeout": 30 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Briefly check this turn. Flag ONLY if: 1) Files modified without tests. 2) AI features without evaluation tests. 3) Commits to main. 4) TODO/FIXME added without tracking issue. Say nothing if clean.",
            "model": "haiku"
          }
        ]
      }
    ]
  }
}
